# Lokale Medien-Originale (M-3c: Master liegt in Shopify Files, lokale Kopien sind Backup)
_media-source/**
!_media-source/.gitkeep
!_media-source/*/.gitkeep

# Dependencies
node_modules/
bun.lock

# Build-Artefakte (Adapter-Outputs sind transient)
adapters/*/dist/
adapters/*/.cache/

# Editor-/OS-Dateien
.DS_Store
.vscode/
.idea/
*.swp
*.orig
*.bak

# Secrets (.env-Dateien IMMER ignoriert, niemals committen)
.env
.env.*
!.env.*.template

# Lokale Logs
*.log
logs/

# CW-009 Mirror-Sync — Runtime-State + Logs sind pro-Mac-lokal
.cw-mirror-state
.cw-mirror-divergence
/_archive/_mirror-logs/

# Archivierte Binär-Blobs (z. B. entfernte WP-Plugins in _archive/)
# Metadaten zu Archiven gehören in specs/*/evidence/ bzw. in Self-Check-Dokumente,
# nicht als vollständiger Ordner ins Git. README bleibt lokal im Archive-Ordner.
# Root-_archive/: partial tracking (sessions only — klein, projekt-spezifisch).
# Sanitizer-Artefakte sind seit 2026-04-24 im Nexus (LL-047 Verortungsregel).
/_archive/*
!/_archive/sessions/
!/_archive/sessions/**
# Sub-Projekt-Archive (z. B. sites/praxis-webseite/_archive/santapress-*) bleiben ignoriert
sites/*/_archive/

# Transient Verify-Screenshots (neu generiert bei jedem verify.sh-Lauf).
# Echte Evidenz-Screenshots gehören nach specs/*/evidence/, nicht ins Rolling-Archiv.
sites/*/screenshots/claude/

# CW-008 — Cross-site-transfer backups (local only)
adapters/*/.backups/

# theme-path Demo-Fallback (Adapter-Output, wenn kein CORTEX_THEME_PATH gesetzt)
.demo-theme/

# Site-level DB backups (S65: pre-insert MySQL dumps, ~17 MB each, transient rollback points)
sites/*/_backups/

# Drift-Sync — Drift-Reports sind zeitstempel-spezifisch, nicht git-trackbar wertvoll.
# Spec: specs/drift-sync/SPEC.md
tools/drift-sync/reports/

# Welle F Phase B — Build-Artefakte (nicht ins Repo: DB-Dumps, Tarballs, Live-Credentials)
sites/praxis-webseite/_deploy/welle-F-phase-B/*/db-*.sql
sites/praxis-webseite/_deploy/welle-F-phase-B/*/wp-config-live.php
sites/praxis-webseite/_deploy/welle-F-phase-B/*/*.tar.gz
sites/praxis-webseite/_deploy/welle-F-phase-B/*/extract.php
sites/praxis-webseite/_deploy/welle-F-phase-B/*/import-db.php
sites/praxis-webseite/_deploy/welle-F-phase-B/*/wp-salts.txt
sites/praxis-webseite/_deploy/welle-F-phase-A/*/.htpasswd
adapters/astro/.backups/
sites/sanexio-github-io/repo/
