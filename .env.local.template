# Cortex-Web — lokale Credentials für POC-Adapter
# Diese Datei nach .env.local kopieren und befüllen. .env.local ist git-ignoriert.

# ─── WordPress (Phase 1) ──────────────────────────────────────────────────────

# WP REST-API Basis-URL (ohne trailing slash, inkl. /wp-json)
WP_REST_BASE=http://gpmedicalcenterwestend-7ded2f4ae8c4343d2029-202604.local/wp-json

# WordPress-Benutzer (der das Application-Password besitzt, typ. Admin)
WP_USER=

# Application-Password aus Local-WP-Admin (Benutzer → Profil → Anwendungspasswörter)
# Format: mit Leerzeichen wie WP es ausgibt, z.B. "xxxx xxxx xxxx xxxx xxxx xxxx"
WP_APP_PASSWORD=

# Optional: Page-Status bei Erstanlage (publish | draft). Default: publish.
# WP_PAGE_STATUS=publish

# ─── Shopify (Phase 2) ────────────────────────────────────────────────────────

# Shopify App Client-ID (aus Dev Dashboard → App → Einstellungen → Anmeldedaten).
# Client-ID ist nicht geheim, darf im Repo stehen.
SHOPIFY_CLIENT_ID=19fe6e2bd121da1592ac75d27b167e72

# Shopify App Client-Secret (aus Dev Dashboard → Einstellungen → Schlüssel, Auge-Symbol).
# Wird NUR für den einmaligen OAuth-Code-Exchange gebraucht.
SHOPIFY_CLIENT_SECRET=

# Store-Domain im Format <handle>.myshopify.com
# Wird vom OAuth-Catcher automatisch geschrieben.
SHOPIFY_STORE=

# Admin-API-Access-Token, beginnt mit "shpat_…".
# Wird vom OAuth-Catcher (tools/shopify-oauth-catcher.mjs) automatisch gesetzt.
SHOPIFY_ADMIN_TOKEN=
