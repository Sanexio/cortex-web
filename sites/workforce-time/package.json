{
  "name": "@cortex-web/workforce-time",
  "version": "0.1.0",
  "description": "Workforce-Time-App (Arbeitszeiten + Schichtplanung). Generisch im Trunk, Tenant-Daten via CORTEX_TENANT_DIR + tools/lib/tenant-{path,config}.mjs.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "api": "node server/api.js",
    "dev": "node server/dev.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test:auth": "node --test server/auth-smoke.test.mjs",
    "test:smtp": "node --test server/smtp.test.mjs",
    "test:payroll": "node --test server/payroll-export.test.mjs",
    "test:ordio": "node --test tools/ordio/ordio-delta.test.mjs",
    "test:backup": "node --test tools/backup-restore.test.mjs",
    "test:setup": "node --test tools/setup-workforce-tenant.test.mjs server/auth-tenant.test.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "extract-tenant-seed": "node tools/extract-tenant-seed.mjs",
    "build:handbuch": "node tools/build-handbuch.mjs",
    "restore-db": "bash tools/restore-db.sh",
    "ordio:delta": "node tools/ordio/ordio-delta.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
