{
  "name": "@cortex-web/workforce-time",
  "version": "0.1.0",
  "description": "Workforce-Time-App (Arbeitszeiten + Schichtplanung). Generisch im Trunk, Tenant-Daten via CORTEX_TENANT_DIR + tools/lib/tenant-{path,config}.mjs.",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "node server/api.js",
    "dev": "node server/dev.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "extract-tenant-seed": "node tools/extract-tenant-seed.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
