# T-101 local subdomain + Mailpit defaults.
# Copy values into your shell, not into a committed .env file.

NODE_ENV=development
WORKFORCE_AUTH_DISABLE=1
WORKFORCE_PUBLIC_BASE_URL=http://arbeitszeiten.localhost

# Local Caddy upstreams.
WORKFORCE_LOCAL_HOST=arbeitszeiten.localhost
WORKFORCE_MAILPIT_HOST=mail.arbeitszeiten.localhost
ARBEITSZEITEN_WEB=127.0.0.1:5174
ARBEITSZEITEN_API=127.0.0.1:5175
MAILPIT_UI=127.0.0.1:8025

# Tenant auth.smtp equivalent for local testing:
# host=127.0.0.1, port=1025, secure=false, require_tls=false.
