# Sanexio-Portal Deploy-Credentials.
#
# Kopiere nach .env.deploy.local (gitignored) und trage Werte ein.
# Werden von tools/deploy-to-portal-sanexio-de.sh gelesen.
#
# Hinweis: westend-hausarzt.com cPanel-Account kann sanexio.de-Subdomains
# verwalten, sofern Subdomain in cPanel angelegt ist (DocRoot dann
# /public_html/portal.sanexio.de/).

SFTP_HOST=westend-hausarzt.com
SFTP_USERNAME=claude-backup@westend-hausarzt.com
SFTP_PASSWORD=<aus existing .env.sprint1.local von praxis-webseite>
SFTP_PORT=21

# DocRoot der Subdomain im cPanel-Account.
# Default-cPanel-Convention: /public_html/<subdomain>/
REMOTE_PATH=/public_html/portal.sanexio.de

LIVE_URL=https://portal.sanexio.de
