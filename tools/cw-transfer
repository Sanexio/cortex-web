#!/usr/bin/env bun
// Cortex-Web — Meta-Orchestrator für alle cross-site Transfers.
// Dispatcht auf die bestehenden sync-*.sh / extract-*.mjs Tools und ergänzt
// sie mit einer einheitlichen Verb-Grammatik.
//
// cross-site-transfer v1, 2026-04-22.
//
// Verbs:
//   push <target>:<type> <trunk-yaml>    — Trunk -> Site
//   pull <source>:<type> <identifier>    — Site -> Trunk (proto-JSON)
//   diff <target>:<type> <trunk-yaml>    — Trunk vs. Site (read-only)
//   list                                 — alle bekannten Transfers
//   help                                 — dieses Dokument
//
// Target/Source: "shopify" | "wp"
// Type: "page" | "template" | "product" | "theme-file"
//
// Examples:
//   cw-transfer push shopify:template trunk/content/pages/_shared/ueber-uns.yaml
//   cw-transfer push shopify:page     trunk/content/pages/_shared/ueber-uns.yaml
//   cw-transfer pull shopify:page     uber-uns
//   cw-transfer pull shopify:template page.uber-uns
//   cw-transfer pull wp:page          team
//   cw-transfer list

import { spawnSync } from "node:child_process";
import { resolve, dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { RENDERER_REGISTRY as SHOPIFY_RENDERERS } from "../adapters/shopify/lib/renderer-registry.mjs";
import { EXTRACTOR_REGISTRY as SHOPIFY_EXTRACTORS } from "../adapters/shopify/lib/extractor-registry.mjs";
import { RENDERER_REGISTRY as WP_RENDERERS } from "../adapters/wordpress/lib/renderer-registry.mjs";
import { EXTRACTOR_REGISTRY as WP_EXTRACTORS } from "../adapters/wordpress/lib/extractor-registry.mjs";

const REPO_ROOT = resolve(dirname(fileURLToPath(import.meta.url)), "..");

function die(code, msg) {
  process.stderr.write(`cw-transfer: ${msg}\n`);
  process.exit(code);
}

function printHelp() {
  process.stdout.write(`cw-transfer — Cortex-Web cross-site transfer orchestrator

Usage:
  cw-transfer push <target>:<type> <trunk-yaml>     write trunk -> site
  cw-transfer pull <source>:<type> <identifier>     read site -> proto-trunk
  cw-transfer diff <target>:<type> <trunk-yaml>     read-only compare (exit 0=equal, 1=diff, 2=error)
  cw-transfer list                                  show registered renderers / extractors
  cw-transfer help

Target/Source:
  shopify    Tenant-Shopify-Store (über Tenant-Credentials in .env.local)
  wp         Tenant-WordPress-Site (lokal oder Production)

Type:
  page       Simple content page (body_html)
  template   Theme template with sections (pattern B)
  product    Shopify product / WP partner product
  theme-file Theme file via filesystem (planned)

Push currently supported for:
  shopify:page / shopify:template / shopify:product
  wp:product / wp:template (N-1, team data)

Diff currently supported for:
  shopify:page                                      (N-6)
  shopify:template                                  (N-6.2)
  wp:template                                       (N-6.3, arg = renderer handle, e.g. "team")

Diff env (shopify:page):
  PUBLISH=1                                         compare published flag
  FORMAT=json                                       structured output

Diff env (shopify:template):
  SHOPIFY_THEME_ID                                  pin theme (default=live role=main)
  FORMAT=json                                       structured output

Diff env (wp:template):
  THEME_PATH                                        override theme root (default: Local-WP Praxis)
  FORMAT=json                                       structured output

See specs/cross-site-transfer/PATTERNS.md for the 6 transfer patterns.
See specs/cross-site-transfer/N-6_cw-transfer-diff.md for page-diff design.
See specs/cross-site-transfer/N-6.2_cw-transfer-diff-template.md for template-diff design.
See specs/cross-site-transfer/N-6.3_cw-transfer-diff-wp-template.md for wp:template-diff design.
`);
}

// --- dispatch tables ---

// Push dispatch: maps <target>:<type> -> shell tool to invoke
const PUSH_TOOLS = {
  "shopify:page":     "tools/sync-page-shopify.sh",
  "shopify:template": "tools/sync-template-shopify.sh",
  "shopify:product":  "tools/sync-shopify.sh",
  "wp:product":       "tools/sync-wp.sh",
  "wp:template":      "tools/sync-team-wp.sh"  // N-1: team data (Pattern B reverse)
};

// Pull dispatch: maps <source>:<type> -> extractor tool
const PULL_TOOLS = {
  "shopify:page":     "adapters/shopify/extract-page.mjs",
  "shopify:template": "adapters/shopify/extract-template.mjs",
  "wp:page":          "adapters/wordpress/extract-page.mjs"
};

// Diff dispatch: maps <target>:<type> -> read-only diff tool
// (build-then-fetch-then-compare; no writes to the target site)
const DIFF_TOOLS = {
  "shopify:page":     "adapters/shopify/diff-page.mjs",
  "shopify:template": "adapters/shopify/diff-template.mjs",
  "wp:template":      "adapters/wordpress/diff-team.mjs"  // N-6.3: renderer-handle arg (team)
};

function runShell(cmd, args) {
  const res = spawnSync(cmd, args, { cwd: REPO_ROOT, stdio: "inherit" });
  if (res.status !== 0) process.exit(res.status ?? 1);
}

function runStdoutCapture(cmd, args) {
  const res = spawnSync(cmd, args, { cwd: REPO_ROOT, stdio: ["inherit", "inherit", "inherit"] });
  if (res.status !== 0) process.exit(res.status ?? 1);
}

// --- verbs ---

function cmdPush(spec, target) {
  if (!target) die(1, `push: missing trunk-yaml argument`);
  const tool = PUSH_TOOLS[spec];
  if (!tool) die(1, `push: no tool registered for "${spec}" (try: cw-transfer list)`);
  runShell("bash", [tool, target]);
}

function cmdPull(spec, identifier) {
  if (!identifier) die(1, `pull: missing identifier argument`);
  const tool = PULL_TOOLS[spec];
  if (!tool) die(1, `pull: no extractor registered for "${spec}" (try: cw-transfer list)`);
  runStdoutCapture("bun", [tool, identifier]);
}

function cmdDiff(spec, target) {
  // Read-only diff: build the payload locally, fetch the current site state,
  // emit a field-by-field comparison. Exits 0 if equal, 1 if diff present,
  // 2 on error. See specs/cross-site-transfer/N-6_cw-transfer-diff.md.
  if (!target) die(1, `diff: missing trunk-yaml argument`);
  const tool = DIFF_TOOLS[spec];
  if (!tool) die(1, `diff: no diff-tool registered for "${spec}" (try: cw-transfer list)`);
  runShell("bun", [tool, target]);
}

function cmdList() {
  const all = [
    { section: "shopify / renderers (push)",   entries: SHOPIFY_RENDERERS },
    { section: "shopify / extractors (pull)",  entries: SHOPIFY_EXTRACTORS },
    { section: "wordpress / renderers (push)", entries: WP_RENDERERS },
    { section: "wordpress / extractors (pull)", entries: WP_EXTRACTORS }
  ];
  for (const block of all) {
    process.stdout.write(`\n== ${block.section} ==\n`);
    const keys = Object.keys(block.entries);
    if (keys.length === 0) { process.stdout.write("  (none)\n"); continue; }
    for (const key of keys) {
      const v = block.entries[key];
      const status = v.status || "?";
      process.stdout.write(`  [${status.padEnd(9)}] ${key}\n`);
      if (v.tool)         process.stdout.write(`              tool   : ${v.tool}\n`);
      if (v.source_shape) process.stdout.write(`              source : ${v.source_shape}\n`);
      if (v.target_shape) process.stdout.write(`              target : ${v.target_shape}\n`);
      if (v.input)        process.stdout.write(`              input  : ${v.input}\n`);
      if (v.output)       process.stdout.write(`              output : ${v.output}\n`);
    }
  }
  process.stdout.write("\nSee specs/cross-site-transfer/PATTERNS.md for context.\n");
}

// --- drift-Verb (Sanexio→Praxis Auto-Sync, seit 2026-04-29) ---
// Spec: specs/drift-sync/SPEC.md

function cmdDrift(subVerb, ...rest) {
  const driftDir = resolve(REPO_ROOT, "tools", "drift-sync");
  if (!subVerb || subVerb === "help") {
    process.stdout.write(`cw-transfer drift — Sanexio → Praxis Auto-Sync

Usage:
  cw-transfer drift status [--scope=<name>] [--json]      Drift-Bericht (read-only)
  cw-transfer drift sync   [--scope=<name>] [--auto-publish] [--dry-run]
                                                          Auto-Curate + Push (D3 default = WP-draft)
  cw-transfer drift backfill                              Bestehende Trunk-YAMLs mit upstream_source-Block versehen
  cw-transfer drift help                                  diese Hilfe

Scopes (siehe tools/drift-sync/config.json):
  labor             Sanexio-Bluttests-Collection (auto-publish erlaubt)
  untersuchungen    Ultraschall-Untersuchungen (immer draft)
  body-checks       Body-Check-Produkte (immer draft)
  pages-shared      Hub-Pages body-checks/bluttests/biomarker (immer draft)

Drift-Status:
  NEW          Auf Sanexio neu — wird auto-curated angelegt
  UPDATED      Sanexio hat Änderung — Trunk wird aktualisiert (lokale views.practice bleibt)
  LOCAL_DRIFT  Praxis lokal editiert UND Sanexio geändert — STOPP, manuelle Auflösung
  REMOVED      Auf Sanexio nicht mehr — Trunk archiviert, WP auf draft
  CLEAN        Synchron, nichts zu tun

Spec: specs/drift-sync/SPEC.md
`);
    process.exit(0);
  }

  if (subVerb === "status") {
    const args = rest.filter((a) => a !== undefined);
    const result = spawnSync("bun", [join(driftDir, "detect.mjs"), ...args], { stdio: "inherit" });
    process.exit(result.status || 0);
  }

  if (subVerb === "sync") {
    const args = rest.filter((a) => a !== undefined);
    const result = spawnSync("bun", [join(driftDir, "sync.mjs"), ...args], { stdio: "inherit" });
    process.exit(result.status || 0);
  }

  if (subVerb === "backfill") {
    const backfillScript = join(driftDir, "backfill.mjs");
    const result = spawnSync("bun", [backfillScript, ...rest], { stdio: "inherit" });
    process.exit(result.status || 0);
  }

  die(1, `unknown drift sub-verb "${subVerb}" — try: cw-transfer drift help`);
}

// --- main ---

const [, , verb, ...rest] = process.argv;
const [spec, arg] = rest;
switch (verb) {
  case "push": cmdPush(spec, arg); break;
  case "pull": cmdPull(spec, arg); break;
  case "diff": cmdDiff(spec, arg); break;
  case "list": cmdList(); break;
  case "drift": cmdDrift(spec, ...rest.slice(1)); break;
  case "help":
  case undefined:
  case "--help":
  case "-h": printHelp(); break;
  default: die(1, `unknown verb "${verb}" — try: cw-transfer help`);
}
