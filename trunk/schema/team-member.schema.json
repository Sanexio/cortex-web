{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex-web.local/schema/team-member.json",
  "title": "TeamMember",
  "description": "Team-Mitglied. Tenant-rollen-abstrakt — role und intro sind tenant-spezifischer Freitext.",
  "type": "object",
  "required": ["id", "slug", "name", "role", "languages", "intro", "accent", "order"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable key, entspricht üblicherweise dem slug"
    },
    "order": {
      "type": "integer",
      "minimum": 1,
      "description": "Display-Reihenfolge im Team-Grid (1 = zuerst)"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-slug, z.B. 'dr-example'"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Vollständiger formeller Name inkl. Titel"
    },
    "role": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string" },
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      }
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["de", "en", "fr", "es", "ru", "it", "pt-pt"]
      },
      "uniqueItems": true
    },
    "intro": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string", "minLength": 10 },
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      }
    },
    "accent": {
      "type": "string",
      "enum": ["red", "amber", "ink"]
    },
    "image": {
      "type": ["string", "integer", "null"],
      "description": "Either a media:// URI (future N-1b resolver), a numeric WP attachment id (Block A shortcut, Session 32), or null."
    },
    "image_asset_shop": {
      "type": ["string", "null"],
      "description": "Dateiname im Shopify-Theme-Asset-Ordner (z.B. 'dr-example.jpg'). Wird an `asset_image` im Template weitergegeben. null = Placeholder-SVG."
    },
    "qualifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pills im Shop-Template (Shopify). Kommagetrennt im Template-Settings."
    },
    "bio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string" },
        "en": { "type": "string" }
      },
      "description": "Ausführliche Biografie für Shop-About-Section. Leer = intro wird benutzt."
    },
    "profile_urls": {
      "type": "object",
      "description": "Pro-Role-Profil-URLs (optional). Wenn nicht gesetzt, linkt kein Detail.",
      "additionalProperties": false,
      "properties": {
        "practice": { "type": "string" },
        "shop": { "type": ["string", "null"] }
      }
    }
  }
}
