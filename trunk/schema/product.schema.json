{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex-web.local/schemas/product-v1.json",
  "title": "Product",
  "description": "Cortex-Web Produkt. I-2 hybrid i18n: sprach-invariante Felder auf Top-Level, mehrsprachige Felder verschachtelt unter .de/.en/.fr/.es. Role-Keys (shop/practice) sind tenant-rollen-abstrakt. HWG-Gate: views.practice.show_price MUSS false sein. Externe practice-CTA-Domains werden tenant-spezifisch über tenant.config.json (allowed_external_cta_domains) im Build-Step validiert.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "sku", "category", "status", "parameters", "title", "views"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Stabile Kennung, wird als WP-Page-Slug verwendet"
    },
    "sku": {
      "type": "string",
      "description": "Shopify-SKU (sprach-invariant)"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "status": {
      "enum": ["active", "draft", "archived"]
    },
    "price_eur": {
      "type": "number",
      "minimum": 0,
      "description": "Shop-Preis, wird von Practice-View ignoriert (HWG)"
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hero": { "type": "string", "pattern": "^media://" },
        "gallery": {
          "type": "array",
          "items": { "type": "string", "pattern": "^media://" }
        }
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "einheit"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "einheit": { "type": "string", "minLength": 1 }
        }
      }
    },
    "title": { "$ref": "#/definitions/i18nString" },
    "tagline": { "$ref": "#/definitions/i18nString" },
    "beschreibung": { "$ref": "#/definitions/i18nString" },
    "views": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shop", "practice"],
      "properties": {
        "shop": {
          "type": "object",
          "additionalProperties": false,
          "required": ["show_price", "cta_label", "cta_url"],
          "properties": {
            "show_price": { "type": "boolean" },
            "cta_label": { "$ref": "#/definitions/i18nString" },
            "cta_url": { "type": "string", "minLength": 1 }
          }
        },
        "practice": {
          "type": "object",
          "additionalProperties": false,
          "required": ["show_price", "cta_label", "cta_url"],
          "properties": {
            "show_price": {
              "type": "boolean",
              "const": false,
              "description": "HWG: Practice-View darf niemals Preis anzeigen"
            },
            "headline_override": { "$ref": "#/definitions/i18nString" },
            "cta_label": { "$ref": "#/definitions/i18nString" },
            "cta_url": {
              "type": "string",
              "pattern": "^(/|https://)",
              "description": "Practice-CTA darf nur intern (/) oder auf eine zugelassene externe Domain zeigen. Die Whitelist wird tenant-spezifisch in tenant.config.json unter `allowed_external_cta_domains` gepflegt und im Build-Step (adapters/wordpress/build.mjs) gegen externe Hosts geprüft."
            }
          }
        }
      }
    },
    "sanexio_source": {
      "type": "object",
      "description": "Provenance-Block (drift-sync seit 2026-04-29). Verknüpft Trunk-YAML mit Upstream-Source. Auch bei lokal editiertem Practice-Content bleibt der Bezug erhalten. Spec: specs/drift-sync/SPEC.md §E2.",
      "required": ["type", "handle", "resource_id", "last_synced_at", "last_synced_hash"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["page", "product"] },
        "handle": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "collection": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "resource_id": { "type": "integer", "minimum": 1 },
        "scope": { "type": "string", "enum": ["labor", "untersuchungen", "body-checks", "pages-shared", "ultraschall", "funktion", "check-up"] },
        "last_synced_at": { "type": "string", "format": "date-time" },
        "last_synced_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "drift_strategy": { "type": "string", "enum": ["auto-curate", "manual", "frozen"], "default": "auto-curate" },
        "local_edits": { "type": "boolean", "default": false }
      }
    }
  },
  "definitions": {
    "i18nString": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "fr": { "type": "string", "minLength": 1 },
        "es": { "type": "string", "minLength": 1 }
      }
    }
  }
}
