{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex-web.local/schema/page.json",
  "title": "Page",
  "description": "Inhaltsseite (shared / praxis-only / juvantis-only / sanexio-only). Konkretisiert in content-bridge-v1 (2026-04-22). Erweitert in cw-astro-adapter Phase 1 (2026-05-23) um sanexio-Site-Enum für die Brand-Hub-Seite sanexio.github.io.",
  "type": "object",
  "required": ["id", "site", "slugs", "title", "sections"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "site": {
      "type": "string",
      "enum": ["praxis", "juvantis", "sanexio", "shared"]
    },
    "slugs": {
      "type": "object",
      "description": "Pro-Site-Slug. Bei site=shared sind beide / drei sinnvoll.",
      "additionalProperties": false,
      "properties": {
        "praxis": { "type": "string", "pattern": "^[a-z0-9/-]+$" },
        "juvantis": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "sanexio": { "type": "string", "pattern": "^[a-z0-9/-]+$" }
      }
    },
    "title": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string" },
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      }
    },
    "status_juvantis": {
      "type": "string",
      "enum": ["draft", "active"],
      "default": "draft"
    },
    "status_sanexio": {
      "type": "string",
      "enum": ["draft", "active"],
      "default": "draft",
      "description": "Phase-1-Astro-Adapter konsumiert nur Pages mit status_sanexio=active oder site=sanexio."
    },
    "views": {
      "type": "object",
      "description": "Site-spezifische Settings (HWG-Trennung). Frei-Form pro View, Renderer prüft.",
      "additionalProperties": true
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "body_md"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "intro" },
              "heading": {
                "type": "object",
                "required": ["de"],
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "body_md": {
                "type": "object",
                "required": ["de"],
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "members"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "team-grid" },
              "heading": {
                "type": "object",
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "members": {
                "oneOf": [
                  { "const": "all" },
                  {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                    "minItems": 1
                  }
                ]
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "body_html"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "service-body" },
              "body_html": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "heading"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "hero" },
              "eyebrow": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "lead": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "image": {
                "type": "string",
                "description": "Optional Hero-Bild — lokaler image-key (shopify-mirror://...) oder absoluter Pfad. Wenn gesetzt, rendert Hero als 2-Spalten-Layout (Bild + Text)."
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "heading", "text"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "usp-box" },
              "variant": {
                "type": "string",
                "enum": ["dark", "light"],
                "default": "dark"
              },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "text": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "items"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "bento-grid" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "title", "href"],
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                    "title": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "teaser": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "image": {
                      "type": "string",
                      "description": "Lokaler image-key (mirror) ODER vollständiger absoluter Pfad"
                    },
                    "href": { "type": "string" },
                    "external": { "type": "boolean", "default": false }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "steps"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "process-steps" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["num", "title", "text"],
                  "additionalProperties": false,
                  "properties": {
                    "num": { "type": "string" },
                    "title": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "text": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "body" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "body_md": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              },
              "body_html": {
                "type": "object",
                "additionalProperties": false,
                "description": "1:1 HTML (für gemirrorte Sanexio-Description). Renderer sanitisiert via wp_kses_post. Builder bevorzugt body_html, fällt sonst auf body_md zurück.",
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              }
            },
            "anyOf": [
              { "required": ["body_md"] },
              { "required": ["body_html"] }
            ]
          },
          {
            "type": "object",
            "required": ["type", "heading"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "cta-banner" },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "sub": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "cta_label": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "cta_url": { "type": "string" }
            }
          }
        ]
      }
    },
    "wp": {
      "type": "object",
      "description": "WP-spezifische Render-Hints: page-template, parent, eyebrow, sub. Nur wp-Adapter konsumiert.",
      "additionalProperties": false,
      "properties": {
        "page_template": {
          "type": "string",
          "pattern": "^template-[a-z0-9-]+\\.php$"
        },
        "parent_slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Slug der WP-Parent-Page. Adapter resolved das zur ID zur Push-Zeit."
        },
        "eyebrow": {
          "type": "object",
          "required": ["de"],
          "additionalProperties": false,
          "properties": {
            "de": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "sub": {
          "type": "object",
          "required": ["de"],
          "additionalProperties": false,
          "properties": {
            "de": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "legacy_ids": {
          "type": "array",
          "description": "Bestehende WP-Page-IDs, die diesen Inhalt tragen. Adapter nutzt slug-Lookup, aber IDs dokumentieren Legacy-Zuordnung.",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "sanexio_source": {
      "type": "object",
      "description": "Provenance-Block (LL-053-konform, drift-sync seit 2026-04-29). Verknüpft Trunk-YAML mit Sanexio-Source. Auch bei lokal editiertem Praxis-Content bleibt der Bezug erhalten. Spec: specs/drift-sync/SPEC.md §E2.",
      "required": ["type", "handle", "resource_id", "last_synced_at", "last_synced_hash"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["page", "product"],
          "description": "Shopify-Resource-Typ"
        },
        "handle": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Shopify-Handle (= Slug). Convenience, kann sich ändern; resource_id ist stabil."
        },
        "collection": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Sanexio-Collection-Handle (nur bei type=product)."
        },
        "resource_id": {
          "type": "integer",
          "minimum": 1,
          "description": "Shopify-Numerische-ID — STABIL über Handle-Renaming, primärer Drift-Anker."
        },
        "scope": {
          "type": "string",
          "enum": ["labor", "untersuchungen", "body-checks", "pages-shared", "ultraschall", "funktion", "check-up"],
          "description": "Logischer Drift-Scope (siehe tools/drift-sync/config.json)."
        },
        "last_synced_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 Timestamp des letzten erfolgreichen Sync."
        },
        "last_synced_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 der canonicalized Source-Daten (preis-unabhängig). Drift-Vergleich gegen current_hash."
        },
        "drift_strategy": {
          "type": "string",
          "enum": ["auto-curate", "manual", "frozen"],
          "default": "auto-curate",
          "description": "auto-curate: Auto-Sync (D3 Default) · manual: Drift wird nur gemeldet · frozen: kein Drift-Check"
        },
        "local_edits": {
          "type": "boolean",
          "default": false,
          "description": "true = Praxis-Content wurde lokal angepasst. Auto-Sync stoppt bei Drift (LOCAL_DRIFT-Strategie)."
        }
      }
    }
  }
}
