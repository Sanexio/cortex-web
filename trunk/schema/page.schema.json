{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex-web.local/schema/page.json",
  "title": "Page",
  "description": "Inhaltsseite (shared / praxis-only / juvantis-only). Konkretisiert in content-bridge-v1 (2026-04-22).",
  "type": "object",
  "required": ["id", "site", "slugs", "title", "sections"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "site": {
      "type": "string",
      "enum": ["praxis", "juvantis", "shared"]
    },
    "slugs": {
      "type": "object",
      "description": "Pro-Site-Slug. Bei site=shared sind beide sinnvoll.",
      "additionalProperties": false,
      "properties": {
        "praxis": { "type": "string", "pattern": "^[a-z0-9/-]+$" },
        "juvantis": { "type": "string", "pattern": "^[a-z0-9-]+$" }
      }
    },
    "title": {
      "type": "object",
      "required": ["de"],
      "additionalProperties": false,
      "properties": {
        "de": { "type": "string" },
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      }
    },
    "status_juvantis": {
      "type": "string",
      "enum": ["draft", "active"],
      "default": "draft"
    },
    "views": {
      "type": "object",
      "description": "Site-spezifische Settings (HWG-Trennung). Frei-Form pro View, Renderer prüft.",
      "additionalProperties": true
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "body_md"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "intro" },
              "heading": {
                "type": "object",
                "required": ["de"],
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "body_md": {
                "type": "object",
                "required": ["de"],
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "members"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "team-grid" },
              "heading": {
                "type": "object",
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "members": {
                "oneOf": [
                  { "const": "all" },
                  {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                    "minItems": 1
                  }
                ]
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "body_html"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "service-body" },
              "body_html": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "heading"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "hero" },
              "eyebrow": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "lead": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "image": {
                "type": "string",
                "description": "Optional Hero-Bild — lokaler image-key (shopify-mirror://...) oder absoluter Pfad. Wenn gesetzt, rendert Hero als 2-Spalten-Layout (Bild + Text)."
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "heading", "text"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "usp-box" },
              "variant": {
                "type": "string",
                "enum": ["dark", "light"],
                "default": "dark"
              },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "text": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "items"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "bento-grid" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "title", "href"],
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                    "title": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "teaser": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "image": {
                      "type": "string",
                      "description": "Lokaler image-key (mirror) ODER vollständiger absoluter Pfad"
                    },
                    "href": { "type": "string" },
                    "external": { "type": "boolean", "default": false }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "steps"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "process-steps" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["num", "title", "text"],
                  "additionalProperties": false,
                  "properties": {
                    "num": { "type": "string" },
                    "title": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    },
                    "text": {
                      "type": "object",
                      "required": ["de"],
                      "additionalProperties": false,
                      "properties": {
                        "de": { "type": "string" },
                        "en": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "body" },
              "heading": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "body_md": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              },
              "body_html": {
                "type": "object",
                "additionalProperties": false,
                "description": "1:1 HTML (für gemirrorte Sanexio-Description). Renderer sanitisiert via wp_kses_post. Builder bevorzugt body_html, fällt sonst auf body_md zurück.",
                "properties": {
                  "de": { "type": "string", "minLength": 1 },
                  "en": { "type": "string" }
                }
              }
            },
            "anyOf": [
              { "required": ["body_md"] },
              { "required": ["body_html"] }
            ]
          },
          {
            "type": "object",
            "required": ["type", "heading"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "cta-banner" },
              "heading": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "sub": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "cta_label": {
                "type": "object",
                "required": ["de"],
                "additionalProperties": false,
                "properties": {
                  "de": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "cta_url": { "type": "string" }
            }
          }
        ]
      }
    },
    "wp": {
      "type": "object",
      "description": "WP-spezifische Render-Hints: page-template, parent, eyebrow, sub. Nur wp-Adapter konsumiert.",
      "additionalProperties": false,
      "properties": {
        "page_template": {
          "type": "string",
          "pattern": "^template-[a-z0-9-]+\\.php$"
        },
        "parent_slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Slug der WP-Parent-Page. Adapter resolved das zur ID zur Push-Zeit."
        },
        "eyebrow": {
          "type": "object",
          "required": ["de"],
          "additionalProperties": false,
          "properties": {
            "de": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "sub": {
          "type": "object",
          "required": ["de"],
          "additionalProperties": false,
          "properties": {
            "de": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "legacy_ids": {
          "type": "array",
          "description": "Bestehende WP-Page-IDs, die diesen Inhalt tragen. Adapter nutzt slug-Lookup, aber IDs dokumentieren Legacy-Zuordnung.",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
