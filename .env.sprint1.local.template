# Sprint 1 — Credentials-Template
#
# Kopieren Sie diese Datei nach `.env.sprint1.local` und füllen Sie die Werte aus.
# Die Datei `.env.sprint1.local` ist durch `.gitignore` ausgeschlossen und landet
# NIE im Git-Repo. Sie bleibt lokal auf Ihrem Mac.
#
# Sie müssen NICHT alle Werte auf einmal ausfüllen — nur die für den aktuellen
# Teilschritt:
#
#   S1.1 Staging anlegen        → DF_*, SFTP_DE_*, MYSQL_DE_*
#   S1.2 Backup + Restore-Probe → WP_COM_ADMIN_*
#   S1.3 Mail-Test              → SMTP_*
#
# Ich lese immer nur die Zeilen, die ich für den aktuellen Teilschritt brauche.

# ============================================================================
# Für S1.1 — Staging-Anlage bei Domainfactory
# ============================================================================

# Domainfactory-Kundencenter (https://customer.df.eu/ oder ähnlich)
DF_LOGIN_URL=
DF_USERNAME=
DF_PASSWORD=

# SFTP-Zugang zum Webspace der `.de`-Domain
# (finden Sie im DF-Panel unter "FTP-Zugänge" oder "SSH-Zugänge")
SFTP_DE_HOST=
SFTP_DE_PORT=22
SFTP_DE_USERNAME=
SFTP_DE_PASSWORD=
SFTP_DE_ROOT_PATH=

# MySQL-Zugang für die neue WordPress-Installation auf `.de`
# (DB kann ich auch neu anlegen, falls noch keine existiert — dann einfach leer lassen)
MYSQL_DE_HOST=
MYSQL_DE_PORT=3306
MYSQL_DE_DATABASE=
MYSQL_DE_USERNAME=
MYSQL_DE_PASSWORD=

# ============================================================================
# Für S1.2 — Backup der Prod-Site `.com`
# ============================================================================

# WP-Admin für westend-hausarzt.com (nur Lesezugriff auf AkeebaBackup-Plugin nötig)
WP_COM_ADMIN_URL=https://westend-hausarzt.com/wp-admin/
WP_COM_ADMIN_USERNAME=
WP_COM_ADMIN_PASSWORD=

# SFTP `.com`-Webspace (falls abweichend von `.de` — sonst leer lassen, dann nehme ich obige)
SFTP_COM_HOST=
SFTP_COM_PORT=22
SFTP_COM_USERNAME=
SFTP_COM_PASSWORD=
SFTP_COM_ROOT_PATH=

# ============================================================================
# Für S1.3 — Outlook-SMTP für Mail-Test
# ============================================================================

# SMTP-Server (für Outlook/Microsoft 365 meist smtp.office365.com, Port 587, STARTTLS)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls

# SMTP-Anmeldedaten
# WICHTIG: Wenn Sie Zwei-Faktor-Authentifizierung nutzen, brauchen Sie ein
# "App-Passwort", nicht Ihr normales Outlook-Passwort. Erstellt wird es unter:
#   https://account.microsoft.com/security
#   → Erweiterte Sicherheitsoptionen → App-Passwörter → Neues App-Passwort
SMTP_USERNAME=praxis@westend-hausarzt.de
SMTP_APP_PASSWORD=

# From-Header (wird in jeder Mail angezeigt)
SMTP_FROM_ADDRESS=praxis@westend-hausarzt.de
SMTP_FROM_NAME=Praxiszentrum Bewerbung
